generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── Cache Models (Public Route Cache) ──────────────────────────────────────────

model RepoCache {
  id        String   @id @default(cuid())
  fullName  String   @unique
  owner     String
  repo      String
  data      Json
  cachedAt  DateTime @default(now())

  @@index([owner, repo])
}

model CommitCache {
  id        String   @id @default(cuid())
  fullName  String
  sha       String
  data      Json
  summary   String?
  cachedAt  DateTime @default(now())

  @@unique([fullName, sha])
  @@index([fullName])
}

model PullRequestCache {
  id        String   @id @default(cuid())
  fullName  String
  prNumber  Int
  data      Json
  summary   String?
  cachedAt  DateTime @default(now())

  @@unique([fullName, prNumber])
  @@index([fullName])
}

// ─── Application Models ────────────────────────────────────────────────────────

model Project {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  name      String
  githubUrl String
  deletedAt DateTime?

  commits              Commit[]
  sourceCodeEmbeddings SourceCodeEmbedding[]
  pullRequests         PullRequest[]
}

model SourceCodeEmbedding {
  id               String                        @id @default(cuid())
  summaryEmbedding Unsupported("vector(3072)")?
  sourceCode       String
  fileName         String
  summary          String
  projectId        String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Commit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId          String
  commitMessage      String
  commitHash         String
  commitAuthorName   String
  commitAuthorAvatar String
  commitDate         DateTime
  summary            String
  rawDiff            String?

  project Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  files   CommitFile[]
}

model CommitFile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commitId  String
  fileName  String
  status    String
  additions Int      @default(0)
  deletions Int      @default(0)
  patch     String?

  aiSummary           String?
  aiSummaryGeneratedAt DateTime?

  commit Commit @relation(fields: [commitId], references: [id], onDelete: Cascade)

  @@index([commitId])
  @@index([commitId, fileName])
}

model PullRequest {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projectId     String
  prNumber      Int
  title         String
  body          String?
  state         String
  authorName    String
  authorAvatar  String?
  baseBranch    String
  headBranch    String
  additions     Int      @default(0)
  deletions     Int      @default(0)
  changedFiles  Int      @default(0)
  mergedAt      DateTime?
  closedAt      DateTime?
  aiSummary     String?

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  files   PullRequestFile[]

  @@unique([projectId, prNumber])
  @@index([projectId])
}

model PullRequestFile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pullRequestId String
  fileName      String
  status        String
  additions     Int      @default(0)
  deletions     Int      @default(0)
  patch         String?

  aiSummary           String?
  aiSummaryGeneratedAt DateTime?

  pullRequest PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)

  @@index([pullRequestId])
}
